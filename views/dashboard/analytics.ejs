                        <i class="fas fa-trash"></i> Permanently Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Toast Container for Notifications -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
    <div id="successToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="fas fa-check-circle"></i> <span id="successMessage"></span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
    <div id="errorToast" class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="fas fa-exclamation-circle"></i> <span id="errorMessage"></span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>

<script>
// Prepare data for chart
// @ts-ignore - EJS template syntax
const dailyClicksData = <%- JSON.stringify(dailyClicks) %>;

// Create labels and data arrays
const labels = dailyClicksData.map(d => {
    const date = new Date(d._id);
    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
});

const data = dailyClicksData.map(d => d.count);

// Create chart
const ctx = document.getElementById('clicksChart').getContext('2d');
const clicksChart = new Chart(ctx, {
    type: 'line',
    data: {
        labels: labels,
        datasets: [{
            label: 'Clicks',
            data: data,
            borderColor: 'rgb(75, 192, 192)',
            backgroundColor: 'rgba(75, 192, 192, 0.2)',
            tension: 0.4,
            fill: true
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
            legend: {
                display: false
            },
            tooltip: {
                mode: 'index',
                intersect: false,
            }
        },
        scales: {
            y: {
                beginAtZero: true,
                ticks: {
                    stepSize: 1
                }
            }
        }
    }
});

// View link details function
function viewLinkDetails(linkId) {
    window.location.href = `/analytics/link/${linkId}`;
}

// Toast helper function
function showToast(type, message) {
    const toastEl = document.getElementById(type + 'Toast');
    const messageEl = document.getElementById(type + 'Message');
    messageEl.textContent = message;
    const toast = new bootstrap.Toast(toastEl, {
        autohide: true,
        delay: 3000
    });
    toast.show();
}

// Restore archived link
let linkToRestore = null;

function restoreLink(linkId) {
    linkToRestore = linkId;
    const modal = new bootstrap.Modal(document.getElementById('restoreLinkModal'));
    modal.show();
}

// Handle restore confirmation
document.addEventListener('DOMContentLoaded', function() {
    const confirmRestoreBtn = document.getElementById('confirmRestoreBtn');
    const restoreLinkModal = document.getElementById('restoreLinkModal');
    
    if (confirmRestoreBtn) {
        confirmRestoreBtn.addEventListener('click', function() {
            if (!linkToRestore) return;
            
            // Disable button and show loading
            confirmRestoreBtn.disabled = true;
            confirmRestoreBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Restoring...';
            
            fetch('/dashboard/restore-link', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ id: linkToRestore })
            })
            .then(response => response.json())
            .then(data => {
                // Close modal
                const modal = bootstrap.Modal.getInstance(restoreLinkModal);
                modal.hide();
                
                if (data.success) {
                    showToast('success', 'Link restored successfully!');
                    setTimeout(() => {
                        window.location.reload();
                    }, 1500);
                } else {
                    showToast('error', 'Failed to restore link: ' + (data.message || 'Unknown error'));
                    // Re-enable button
                    confirmRestoreBtn.disabled = false;
                    confirmRestoreBtn.innerHTML = '<i class="fas fa-undo"></i> Restore Link';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                // Close modal
                const modal = bootstrap.Modal.getInstance(restoreLinkModal);
                modal.hide();
                showToast('error', 'Failed to restore link. Please try again.');
                // Re-enable button
                confirmRestoreBtn.disabled = false;
                confirmRestoreBtn.innerHTML = '<i class="fas fa-undo"></i> Restore Link';
            });
        });
    }
});

// Copy tracking URL to clipboard - CSP compliant version
document.addEventListener('DOMContentLoaded', function() {
    // Add event listeners to all copy buttons
    const copyButtons = document.querySelectorAll('.copy-tracking-btn');
    
    copyButtons.forEach(function(btn) {
        btn.addEventListener('click', function() {
            const linkId = this.getAttribute('data-link-id');
            const input = document.getElementById('trackingUrl-' + linkId);
            
            if (!input) {
                console.error('Input element not found for linkId:', linkId);
                showToast('error', 'Failed to copy URL. Element not found.');
                return;
            }
            
            const textToCopy = input.value;
            console.log('Attempting to copy:', textToCopy);
            
            // Copy to clipboard using modern API
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(textToCopy).then(function() {
                    console.log('Copy successful!');
                    showCopySuccess(btn);
                }).catch(function(err) {
                    console.error('Clipboard API failed:', err);
                    fallbackCopy(input, btn);
                });
            } else {
                fallbackCopy(input, btn);
            }
        });
    });
    
    // Initialize Bootstrap modals
    const restoreModal = new bootstrap.Modal(document.getElementById('restoreModal'));
    const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
    
    // Add event listeners for restore buttons
    const restoreButtons = document.querySelectorAll('.restore-link-btn');
    
    restoreButtons.forEach(function(btn) {
        btn.addEventListener('click', function() {
            const linkId = this.getAttribute('data-link-id');
            const linkTitle = this.getAttribute('data-link-title');
            
            document.getElementById('restoreLinkId').value = linkId;
            document.getElementById('restoreLinkTitle').textContent = linkTitle;
            
            restoreModal.show();
        });
    });
    
    // Handle restore form submission
    document.getElementById('restoreForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const linkId = document.getElementById('restoreLinkId').value;
        
        fetch('/dashboard/restore-link', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ id: linkId })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                restoreModal.hide();
                showSuccessToast('Link restored successfully!');
                setTimeout(() => window.location.reload(true), 1000);
            } else {
                showErrorToast('Failed to restore link: ' + (data.message || 'Unknown error'));
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showErrorToast('Failed to restore link. Please try again.');
        });
    });
    
    // Add event listeners for permanent delete buttons
    const permanentDeleteButtons = document.querySelectorAll('.permanent-delete-link-btn');
    
    permanentDeleteButtons.forEach(function(btn) {
        btn.addEventListener('click', function() {
            const linkId = this.getAttribute('data-link-id');
            const linkTitle = this.getAttribute('data-link-title');
            
            document.getElementById('deleteLinkId').value = linkId;
            document.getElementById('deleteLinkTitle').textContent = linkTitle;
            
            deleteModal.show();
        });
    });
    
    // Handle permanent delete form submission
    document.getElementById('deleteForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const linkId = document.getElementById('deleteLinkId').value;
        
        fetch('/dashboard/permanent-delete-link', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ id: linkId })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                deleteModal.hide();
                showSuccessToast('Link permanently deleted!');
                setTimeout(() => window.location.reload(true), 1000);
            } else {
                showErrorToast('Failed to delete link: ' + (data.message || 'Unknown error'));
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showErrorToast('Failed to delete link. Please try again.');
        });
    });
});

// Toast notification functions
function showSuccessToast(message) {
    document.getElementById('successMessage').textContent = message;
    const toast = new bootstrap.Toast(document.getElementById('successToast'));
    toast.show();
}

function showErrorToast(message) {
    document.getElementById('errorMessage').textContent = message;
    const toast = new bootstrap.Toast(document.getElementById('errorToast'));
    toast.show();
}

// Page size change function for analytics clicks pagination - CSP compliant
document.addEventListener('DOMContentLoaded', function() {
    const pageSizeSelector = document.getElementById('clicksPageSize');
    
    if (pageSizeSelector) {
        pageSizeSelector.addEventListener('change', function() {
            const newLimit = this.value;
            const urlParams = new URLSearchParams(window.location.search);
            urlParams.set('limit', newLimit);
            urlParams.set('page', '1'); // Reset to first page when changing page size
            window.location.search = urlParams.toString();
        });
    }
    
    // Page size change for All Links Performance table
    const allLinksPageSize = document.getElementById('allLinksPageSize');
    
    if (allLinksPageSize) {
        const allLinksTable = document.getElementById('allLinksTable');
        
        if (allLinksTable) {
            const tbody = allLinksTable.querySelector('tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));
            const totalLinks = rows.length;
            
            // Set initial display to 10 items
            rows.forEach((row, index) => {
                row.style.display = index < 10 ? '' : 'none';
            });
            
            // Update showing text
            const showingText = document.getElementById('allLinksShowingText');
            if (showingText) {
                const visibleCount = Math.min(10, totalLinks);
                showingText.textContent = `Showing 1-${visibleCount} of ${totalLinks} links`;
            }
            
            // Handle page size change
            allLinksPageSize.addEventListener('change', function() {
                const limit = parseInt(this.value);
                
                if (limit === 100) {
                    // Show all rows
                    rows.forEach(row => row.style.display = '');
                } else {
                    // Show only first 'limit' rows
                    rows.forEach((row, index) => {
                        row.style.display = index < limit ? '' : 'none';
                    });
                }
                
                // Update showing text
                if (showingText) {
                    const visibleCount = limit === 100 ? totalLinks : Math.min(limit, totalLinks);
                    if (limit === 100) {
                        showingText.textContent = `Showing all ${totalLinks} links`;
                    } else {
                        showingText.textContent = `Showing 1-${visibleCount} of ${totalLinks} links`;
                    }
                }
            });
        }
    }
});

// Show success feedback
function showCopySuccess(btn) {
    const originalHTML = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-check"></i>';
    btn.classList.remove('btn-outline-secondary');
    btn.classList.add('btn-success');
    
    setTimeout(function() {
        btn.innerHTML = originalHTML;
        btn.classList.remove('btn-success');
        btn.classList.add('btn-outline-secondary');
    }, 2000);
}

// Fallback copy method for older browsers
function fallbackCopy(input, btn) {
    try {
        input.select();
        input.setSelectionRange(0, 99999);
        const successful = document.execCommand('copy');
        
        if (successful) {
            console.log('Fallback copy successful!');
            showCopySuccess(btn);
        } else {
            throw new Error('execCommand failed');
        }
    } catch (err) {
        console.error('Fallback copy failed:', err);
        showToast('error', 'Failed to copy URL. Please try manually.');
    }
}

</script>

