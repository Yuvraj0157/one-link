<%-include('include/_header')%>

<!-- Toast Container for Notifications -->
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
    <div id="successToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="fas fa-check-circle me-2"></i>
                <span id="successMessage"></span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
    
    <div id="errorToast" class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="fas fa-exclamation-circle me-2"></i>
                <span id="errorMessage"></span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<!-- Restore Link Confirmation Modal -->
<div class="modal fade" id="restoreLinkModal" tabindex="-1" aria-labelledby="restoreLinkModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="restoreLinkModalLabel">
                    <i class="fas fa-undo text-primary"></i> Restore Link
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to restore this link?</p>
                <p class="text-muted small mb-0">It will be visible on your public profile again.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times"></i> Cancel
                </button>
                <button type="button" class="btn btn-primary" id="confirmRestoreBtn">
                    <i class="fas fa-undo"></i> Restore Link
                </button>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <!-- Back to Dashboard Button -->
    <div class="mb-3">
        <a href="/dashboard" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>
    
    <!-- Page Header -->
    <div class="page-header">
        <h1><i class="fas fa-chart-line me-2"></i>Analytics Dashboard</h1>
        <p>Track your profile performance and link engagement</p>
    </div>
    
    
    <!-- Summary Cards -->
    <div class="row" style="margin-top: 30px;">
        <!-- Profile Views - Most Important -->
        <div class="col-lg-3 col-md-6 col-sm-6 mb-3">
            <div class="card text-center" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); color: white;"
                 data-bs-toggle="tooltip" data-bs-placement="top"
                 title="Total number of times your profile page has been viewed since creation">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-eye"></i> Profile Views</h5>
                    <h2 class="card-text"><%= totalViews %></h2>
                    <small>All-time total</small>
                </div>
            </div>
        </div>
        
        <!-- Total Link Clicks -->
        <div class="col-lg-3 col-md-6 col-sm-6 mb-3">
            <div class="card text-center" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;"
                 data-bs-toggle="tooltip" data-bs-placement="top"
                 title="Total clicks on all your links in the last 90 days. Older data is automatically deleted for privacy.">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-mouse-pointer"></i> Link Clicks</h5>
                    <h2 class="card-text"><%= summary.totalClicks %></h2>
                    <small>Last 90 days</small>
                </div>
            </div>
        </div>
        
        <!-- Last 30 Days Link Clicks -->
        <div class="col-lg-3 col-md-6 col-sm-6 mb-3">
            <div class="card text-center" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white;"
                 data-bs-toggle="tooltip" data-bs-placement="top"
                 title="Link clicks in the last 30 days. Monthly performance indicator.">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-mouse-pointer"></i> Link Clicks</h5>
                    <h2 class="card-text"><%= summary.monthClicks %></h2>
                    <small>Last 30 days</small>
                </div>
            </div>
        </div>
        
        <!-- Today's Link Clicks -->
        <div class="col-lg-3 col-md-6 col-sm-6 mb-3">
            <div class="card text-center" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); color: white;"
                 data-bs-toggle="tooltip" data-bs-placement="top"
                 title="Link clicks in the last 24 hours. Real-time activity indicator.">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-mouse-pointer"></i> Link Clicks</h5>
                    <h2 class="card-text"><%= summary.todayClicks %></h2>
                    <small>Last 24 hours</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats Row -->
    <div class="row" style="margin-top: 20px;">
        <div class="col-md-12 mb-4">
            <div class="card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white;">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-chart-bar"></i> Quick Stats</h5>
                    <div class="row text-center" style="margin-top: 15px;">
                        <div class="col-md-4" data-bs-toggle="tooltip" data-bs-placement="top"
                             title="Average number of link clicks per day over the last 90 days">
                            <h3><%= quickStats.avgClicksPerDay %></h3>
                            <small>Avg Clicks/Day</small>
                        </div>
                        <div class="col-md-4" data-bs-toggle="tooltip" data-bs-placement="top"
                             title="Day of the week when your links get the most clicks. Best day to share content!">
                            <h3><%= quickStats.mostActiveDay %></h3>
                            <small>Most Active Day</small>
                        </div>
                        <div class="col-md-4" data-bs-toggle="tooltip" data-bs-placement="top"
                             title="Hour of the day when your links get the most clicks. Best time to post!">
                            <h3><%= quickStats.peakHour %></h3>
                            <small>Peak Hour</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row" style="margin-top: 20px;">
        <!-- Daily Clicks Chart -->
        <div class="col-md-12 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5><i class="fas fa-chart-line"></i> Clicks Over Time (Last 30 Days)</h5>
                </div>
                <div class="card-body">
                    <canvas id="clicksChart" height="80"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Widgets Row - Equal 3 Columns -->
    <div class="row">
        <!-- Device Types -->
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5><i class="fas fa-mobile-alt"></i> Device Types</h5>
                </div>
                <div class="card-body">
                    <% if(deviceStats && deviceStats.length > 0) { %>
                        <ul class="list-group list-group-flush">
                            <% deviceStats.forEach(device => { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center" style="padding: 10px 0;">
                                    <span>
                                        <% if(device._id === 'Mobile') { %>
                                            <i class="fas fa-mobile-alt" style="font-size: 18px; margin-right: 8px;"></i>
                                        <% } else if(device._id === 'Desktop') { %>
                                            <i class="fas fa-desktop" style="font-size: 18px; margin-right: 8px;"></i>
                                        <% } else if(device._id === 'Tablet') { %>
                                            <i class="fas fa-tablet-alt" style="font-size: 18px; margin-right: 8px;"></i>
                                        <% } %>
                                        <span style="font-size: 13px;"><%= device._id %></span>
                                    </span>
                                    <span class="badge bg-primary rounded-pill"><%= device.count %></span>
                                </li>
                            <% }); %>
                        </ul>
                    <% } else { %>
                        <p class="text-muted text-center" style="margin-top: 20px;">
                            <i class="fas fa-mobile-alt" style="font-size: 40px; opacity: 0.3;"></i><br>
                            No device data yet
                        </p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Top Countries -->
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5><i class="fas fa-globe-americas"></i> Top Countries</h5>
                </div>
                <div class="card-body">
                    <% if(summary.topCountries && summary.topCountries.length > 0) { %>
                        <ul class="list-group list-group-flush">
                            <% summary.topCountries.forEach(country => { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center" style="padding: 10px 0;">
                                    <span>
                                        <span style="font-size: 20px; margin-right: 8px;">
                                            <%= String.fromCodePoint(...country.countryCode.toUpperCase().split('').map(c => 127397 + c.charCodeAt())) %>
                                        </span>
                                        <span style="font-size: 13px;"><%= country._id %></span>
                                    </span>
                                    <span class="badge bg-success rounded-pill"><%= country.count %></span>
                                </li>
                            <% }); %>
                        </ul>
                    <% } else { %>
                        <p class="text-muted text-center" style="margin-top: 20px;">
                            <i class="fas fa-globe" style="font-size: 40px; opacity: 0.3;"></i><br>
                            No location data yet
                        </p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Top Referrers -->
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5><i class="fas fa-share-alt"></i> Top Sources</h5>
                </div>
                <div class="card-body">
                    <% if(summary.topReferrers && summary.topReferrers.length > 0) { %>
                        <ul class="list-group list-group-flush">
                            <% summary.topReferrers.forEach(ref => { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center" style="padding: 10px 0;">
                                    <span style="font-size: 12px; overflow: hidden; text-overflow: ellipsis;">
                                        <% if(ref._id === 'direct') { %>
                                            <i class="fas fa-keyboard"></i> Direct
                                        <% } else if(ref._id.includes('twitter')) { %>
                                            <i class="fab fa-twitter"></i> Twitter
                                        <% } else if(ref._id.includes('facebook')) { %>
                                            <i class="fab fa-facebook"></i> Facebook
                                        <% } else if(ref._id.includes('instagram')) { %>
                                            <i class="fab fa-instagram"></i> Instagram
                                        <% } else if(ref._id.includes('google')) { %>
                                            <i class="fab fa-google"></i> Google
                                        <% } else { %>
                                            <i class="fas fa-link"></i> <%= ref._id.substring(0, 15) %>
                                        <% } %>
                                    </span>
                                    <span class="badge bg-primary rounded-pill"><%= ref.count %></span>
                                </li>
                            <% }); %>
                        </ul>
                    <% } else { %>
                        <p class="text-muted text-center" style="margin-top: 20px;">
                            <i class="fas fa-share-alt" style="font-size: 40px; opacity: 0.3;"></i><br>
                            No referrer data yet
                        </p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Links -->
    <div class="row">
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5>Top Performing Links</h5>
                    <a href="/analytics/export?format=csv" class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-download"></i> Export CSV
                    </a>
                </div>
                <div class="card-body">
                    <% if(summary.topLinks && summary.topLinks.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Rank</th>
                                        <th>Link Title</th>
                                        <th>URL</th>
                                        <th>Tracking URL</th>
                                        <th>Clicks</th>
                                        <th data-bs-toggle="tooltip" data-bs-placement="top"
                                            title="Click-Through Rate: Percentage of profile visitors who clicked this link">
                                            CTR <i class="fas fa-info-circle" style="font-size: 10px;"></i>
                                        </th>
                                        <th data-bs-toggle="tooltip" data-bs-placement="top"
                                            title="Performance level based on click count: Excellent (100+), Popular (50+), Growing (20+), Good (5+), New (1-4), No Clicks (0)">
                                            Status <i class="fas fa-info-circle" style="font-size: 10px;"></i>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% summary.topLinks.forEach((link, index) => {
                                        const linkData = linksWithClicks.find(l => l.title === link.title);
                                        const ctr = linkData ? linkData.ctr : 0;
                                        const badge = linkData ? linkData.badge : { icon: '💤', text: 'Inactive', class: 'secondary' };
                                    %>
                                        <tr>
                                            <td>
                                                <% if(index === 0) { %>
                                                    <span style="font-size: 20px;">🥇</span>
                                                <% } else if(index === 1) { %>
                                                    <span style="font-size: 20px;">🥈</span>
                                                <% } else if(index === 2) { %>
                                                    <span style="font-size: 20px;">🥉</span>
                                                <% } else { %>
                                                    <%= index + 1 %>
                                                <% } %>
                                            </td>
                                            <td><strong><%= link.title %></strong></td>
                                            <td>
                                                <a href="<%= link.url %>" target="_blank" style="font-size: 12px;">
                                                    <%= link.url.substring(0, 40) %><%= link.url.length > 40 ? '...' : '' %>
                                                </a>
                                            </td>
                                            <td>
                                                <%
                                                // link._id from aggregate is the linkId
                                                const trackingUrl = `${baseUrl}/track/link/${user.username}/${link._id}`;
                                                const urlId = link._id.toString();
                                                %>
                                                <div class="input-group input-group-sm" style="max-width: 400px;">
                                                    <input type="text" class="form-control form-control-sm"
                                                           value="<%= trackingUrl %>"
                                                           readonly
                                                           id="trackingUrl-<%= urlId %>"
                                                           style="font-size: 11px;">
                                                    <button class="btn btn-outline-secondary btn-sm copy-tracking-btn"
                                                            type="button"
                                                            data-link-id="<%= urlId %>"
                                                            data-bs-toggle="tooltip"
                                                            title="Copy tracking URL">
                                                        <i class="fas fa-copy"></i>
                                                    </button>
                                                </div>
                                            </td>
                                            <td><span class="badge bg-success"><%= link.clicks %></span></td>
                                            <td>
                                                <span class="badge bg-<%= ctr >= 5 ? 'success' : ctr >= 2 ? 'warning' : 'secondary' %>"
                                                      data-bs-toggle="tooltip" data-bs-placement="top"
                                                      title="<%= link.clicks %> clicks out of <%= totalViews %> profile views">
                                                    <%= ctr %>%
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge bg-<%= badge.class %>"
                                                      data-bs-toggle="tooltip" data-bs-placement="top"
                                                      title="<%= link.clicks %> total clicks">
                                                    <i class="<%= badge.icon %>"></i> <%= badge.text %>
                                                </span>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <p class="text-muted">No click data yet. Share your profile to start tracking!</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- All Links with Click Counts -->
    <div class="row">
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5>All Links Performance</h5>
                </div>
                <div class="card-body">
                    <% if(linksWithClicks && linksWithClicks.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-striped" id="allLinksTable">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Link Status</th>
                                        <th>Performance</th>
                                        <th>Title</th>
                                        <th>URL</th>
                                        <th>Clicks</th>
                                        <th>CTR</th>
                                        <th>Tracking URL</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% linksWithClicks.forEach((link, index) => { %>
                                        <tr class="<%= link.isActive ? '' : 'table-warning' %>">
                                            <td><%= index + 1 %></td>
                                            <td>
                                                <% if(link.isActive) { %>
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-check-circle"></i> Active
                                                    </span>
                                                <% } else { %>
                                                    <span class="badge bg-secondary">
                                                        <i class="fas fa-archive"></i> Inactive
                                                    </span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <span class="badge bg-<%= link.badge.class %>">
                                                    <i class="<%= link.badge.icon %>"></i> <%= link.badge.text %>
                                                </span>
                                            </td>
                                            <td><strong><%= link.title %></strong></td>
                                            <td>
                                                <a href="<%= link.url %>" target="_blank" style="font-size: 12px;">
                                                    <%= link.url.substring(0, 50) %><%= link.url.length > 50 ? '...' : '' %>
                                                </a>
                                            </td>
                                            <td><span class="badge bg-info"><%= link.clicks %></span></td>
                                            <td>
                                                <span class="badge bg-<%= link.ctr >= 5 ? 'success' : link.ctr >= 2 ? 'warning' : 'secondary' %>">
                                                    <%= link.ctr %>%
                                                </span>
                                                <small class="text-muted d-block" style="font-size: 10px;">
                                                    <%= link.clicks %> / <%= totalViews %> views
                                                </small>
                                            </td>
                                            <td>
                                                <%
                                                const trackingUrl = `${baseUrl}/track/link/${user.username}/${link._id}`;
                                                const urlId = link._id.toString();
                                                %>
                                                <div class="input-group input-group-sm" style="max-width: 400px;">
                                                    <input type="text" class="form-control form-control-sm"
                                                           value="<%= trackingUrl %>"
                                                           readonly
                                                           id="trackingUrl-all-<%= urlId %>"
                                                           style="font-size: 11px;">
                                                    <button class="btn btn-outline-secondary btn-sm copy-tracking-btn"
                                                            type="button"
                                                            data-link-id="all-<%= urlId %>"
                                                            data-bs-toggle="tooltip"
                                                            title="Copy tracking URL">
                                                        <i class="fas fa-copy"></i>
                                                    </button>
                                                </div>
                                            </td>
                                            <td>
                                                <% if(!link.isActive) { %>
                                                    <div class="btn-group" role="group">
                                                        <button class="btn btn-sm btn-success restore-link-btn"
                                                                type="button"
                                                                data-link-id="<%= link._id %>"
                                                                data-bs-toggle="tooltip"
                                                                title="Restore this link">
                                                            <i class="fas fa-undo"></i>
                                                        </button>
                                                        <button class="btn btn-sm btn-danger permanent-delete-link-btn"
                                                                type="button"
                                                                data-link-id="<%= link._id %>"
                                                                data-link-title="<%= link.title %>"
                                                                data-bs-toggle="tooltip"
                                                                title="Permanently delete this link and all its data">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </div>
                                                <% } else { %>
                                                    <span class="text-muted">-</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                        
                        <!-- Pagination for All Links Performance -->
                        <% if(linksWithClicks.length > 10) { %>
                            <div class="mt-3 pt-3 border-top">
                                <div class="row align-items-center">
                                    <div class="col-md-6 mb-2 mb-md-0">
                                        <div class="d-flex align-items-center">
                                            <label for="allLinksPageSize" class="me-2 mb-0">Items per page:</label>
                                            <select id="allLinksPageSize" class="form-select form-select-sm" style="width: auto;">
                                                <option value="10" selected>10</option>
                                                <option value="25">25</option>
                                                <option value="50">50</option>
                                                <option value="100">All</option>
                                            </select>
                                            <span class="ms-3 text-muted" id="allLinksShowingText">
                                                Showing 1-<%= Math.min(10, linksWithClicks.length) %> of <%= linksWithClicks.length %> links
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    <% } else { %>
                        <p class="text-muted">No links added yet. <a href="/dashboard/add-link">Add your first link</a></p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Clicks -->
    <div class="row">
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5>Recent Activity</h5>
                    <small class="text-muted">
                        <i class="fas fa-clock"></i> Times shown in your local timezone
                    </small>
                </div>
                <div class="card-body">
                    <% if(recentClicks && recentClicks.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead>
                                    <tr>
                                        <th><i class="fas fa-clock"></i> When</th>
                                        <th><i class="fas fa-link"></i> Link Clicked</th>
                                        <th><i class="fas fa-external-link-alt"></i> Destination</th>
                                        <th><i class="fas fa-share-alt"></i> Source</th>
                                        <th><i class="fas fa-globe"></i> Location</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% recentClicks.forEach(click => { %>
                                        <tr>
                                            <td style="font-size: 11px;">
                                                <div class="timestamp-display">
                                                    <div class="relative-time text-primary fw-bold"></div>
                                                    <div class="full-time text-muted" style="font-size: 10px;"></div>
                                                </div>
                                                <script>
                                                    (function() {
                                                        const timestamp = new Date('<%= click.timestamp %>');
                                                        const container = document.currentScript.previousElementSibling;
                                                        
                                                        // Full date/time with timezone
                                                        const fullTime = timestamp.toLocaleString(undefined, {
                                                            year: 'numeric',
                                                            month: 'short',
                                                            day: 'numeric',
                                                            hour: '2-digit',
                                                            minute: '2-digit',
                                                            second: '2-digit',
                                                            timeZoneName: 'short'
                                                        });
                                                        
                                                        // Relative time
                                                        const now = new Date();
                                                        const diffMs = now - timestamp;
                                                        const diffSecs = Math.floor(diffMs / 1000);
                                                        const diffMins = Math.floor(diffSecs / 60);
                                                        const diffHours = Math.floor(diffMins / 60);
                                                        const diffDays = Math.floor(diffHours / 24);
                                                        
                                                        let relativeTime;
                                                        if (diffSecs < 60) {
                                                            relativeTime = 'Just now';
                                                        } else if (diffMins < 60) {
                                                            relativeTime = diffMins === 1 ? '1 minute ago' : `${diffMins} minutes ago`;
                                                        } else if (diffHours < 24) {
                                                            relativeTime = diffHours === 1 ? '1 hour ago' : `${diffHours} hours ago`;
                                                        } else if (diffDays < 7) {
                                                            relativeTime = diffDays === 1 ? 'Yesterday' : `${diffDays} days ago`;
                                                        } else if (diffDays < 30) {
                                                            const weeks = Math.floor(diffDays / 7);
                                                            relativeTime = weeks === 1 ? '1 week ago' : `${weeks} weeks ago`;
                                                        } else if (diffDays < 365) {
                                                            const months = Math.floor(diffDays / 30);
                                                            relativeTime = months === 1 ? '1 month ago' : `${months} months ago`;
                                                        } else {
                                                            const years = Math.floor(diffDays / 365);
                                                            relativeTime = years === 1 ? '1 year ago' : `${years} years ago`;
                                                        }
                                                        
                                                        container.querySelector('.relative-time').textContent = relativeTime;
                                                        container.querySelector('.full-time').textContent = fullTime;
                                                    })();
                                                </script>
                                            </td>
                                            <td><strong><%= click.linkTitle %></strong></td>
                                            <td style="font-size: 11px;">
                                                <a href="<%= click.linkUrl %>" target="_blank" style="text-decoration: none;">
                                                    <%= click.linkUrl.substring(0, 40) %><%= click.linkUrl.length > 40 ? '...' : '' %>
                                                </a>
                                            </td>
                                            <td>
                                                <% if(click.referrer === 'direct') { %>
                                                    <span class="badge bg-secondary">Direct</span>
                                                <% } else if(click.referrer.includes('twitter')) { %>
                                                    <span class="badge bg-info">Twitter</span>
                                                <% } else if(click.referrer.includes('facebook')) { %>
                                                    <span class="badge bg-primary">Facebook</span>
                                                <% } else if(click.referrer.includes('instagram')) { %>
                                                    <span class="badge bg-danger">Instagram</span>
                                                <% } else if(click.referrer.includes('linkedin')) { %>
                                                    <span class="badge bg-primary">LinkedIn</span>
                                                <% } else if(click.referrer.includes('google')) { %>
                                                    <span class="badge bg-success">Google</span>
                                                <% } else { %>
                                                    <span class="badge bg-light text-dark" style="font-size: 10px;">
                                                        <%= click.referrer.substring(0, 20) %>
                                                    </span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if(click.countryCode && click.countryCode !== 'XX') { %>
                                                    <%
                                                    // Convert country code to flag emoji
                                                    const code = click.countryCode.toUpperCase();
                                                    const flag = String.fromCodePoint(...code.split('').map(c => 127397 + c.charCodeAt(0)));
                                                    %>
                                                    <span style="font-size: 20px; margin-right: 5px;"><%= flag %></span>
                                                    <small><%= click.country %></small>
                                                <% } else { %>
                                                    <span class="badge bg-secondary">Unknown</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <p class="text-muted">No clicks recorded yet. Share your profile to start tracking!</p>
                    <% } %>
                    
                    <!-- Pagination Controls for Recent Clicks -->
                    <% if(pagination && pagination.totalPages > 1) { %>
                        <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                            <!-- Page Size Selector -->
                            <div class="d-flex align-items-center">
                                <label for="clicksPageSize" class="me-2 mb-0">Items per page:</label>
                                <select id="clicksPageSize" class="form-select form-select-sm page-size-selector" style="width: auto;">
                                    <option value="10" <%= pagination.limit === 10 ? 'selected' : '' %>>10</option>
                                    <option value="25" <%= pagination.limit === 25 ? 'selected' : '' %>>25</option>
                                    <option value="50" <%= pagination.limit === 50 ? 'selected' : '' %>>50</option>
                                    <option value="100" <%= pagination.limit === 100 ? 'selected' : '' %>>100</option>
                                </select>
                                <span class="ms-3 text-muted">
                                    Showing <%= ((pagination.page - 1) * pagination.limit) + 1 %>-<%= Math.min(pagination.page * pagination.limit, pagination.totalClicks) %>
                                    of <%= pagination.totalClicks %> clicks
                                </span>
                            </div>
                            
                            <!-- Pagination Buttons -->
                            <nav aria-label="Page navigation">
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item <%= !pagination.hasPrev ? 'disabled' : '' %>">
                                        <a class="page-link" href="?page=1&limit=<%= pagination.limit %>" aria-label="First">
                                            <span aria-hidden="true">&laquo;&laquo;</span>
                                        </a>
                                    </li>
                                    <li class="page-item <%= !pagination.hasPrev ? 'disabled' : '' %>">
                                        <a class="page-link" href="?page=<%= pagination.page - 1 %>&limit=<%= pagination.limit %>" aria-label="Previous">
                                            <span aria-hidden="true">&laquo;</span>
                                        </a>
                                    </li>
                                    
                                    <%
                                    const currentPage = pagination.page;
                                    const totalPages = pagination.totalPages;
                                    let startPage = Math.max(1, currentPage - 2);
                                    let endPage = Math.min(totalPages, currentPage + 2);
                                    
                                    if (currentPage <= 3) {
                                        endPage = Math.min(5, totalPages);
                                    }
                                    if (currentPage >= totalPages - 2) {
                                        startPage = Math.max(1, totalPages - 4);
                                    }
                                    
                                    for (let i = startPage; i <= endPage; i++) { %>
                                        <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                            <a class="page-link" href="?page=<%= i %>&limit=<%= pagination.limit %>"><%= i %></a>
                                        </li>
                                    <% } %>
                                    
                                    <li class="page-item <%= !pagination.hasNext ? 'disabled' : '' %>">
                                        <a class="page-link" href="?page=<%= pagination.page + 1 %>&limit=<%= pagination.limit %>" aria-label="Next">
                                            <span aria-hidden="true">&raquo;</span>
                                        </a>
                                    </li>
                                    <li class="page-item <%= !pagination.hasNext ? 'disabled' : '' %>">
                                        <a class="page-link" href="?page=<%= pagination.totalPages %>&limit=<%= pagination.limit %>" aria-label="Last">
                                            <span aria-hidden="true">&raquo;&raquo;</span>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Retention Notice -->
    <div class="row">
        <div class="col-12">
            <div class="alert alert-info" role="alert" style="margin-top: 20px;">
                <i class="fas fa-info-circle"></i>
                <strong>Data Retention:</strong> Analytics data is automatically deleted after 90 days for privacy and storage optimization.
                Export your data regularly if you need long-term records.
            </div>
        </div>
    </div>
</div>

<!-- Restore Link Modal -->
<div class="modal fade" id="restoreModal" tabindex="-1" aria-labelledby="restoreModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="restoreModalLabel">
                    <i class="fas fa-undo"></i> Restore Link
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to restore "<strong id="restoreLinkTitle"></strong>"?</p>
                <div class="alert alert-success mb-0">
                    <i class="fas fa-check-circle"></i> The link will be visible on your public profile again.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="restoreForm" style="display: inline;">
                    <input type="hidden" id="restoreLinkId">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-undo"></i> Restore Link
