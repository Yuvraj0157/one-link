        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="fas fa-exclamation-triangle"></i> Permanent Delete Warning
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">Are you sure you want to <strong>PERMANENTLY DELETE</strong> "<strong id="deleteLinkTitle"></strong>"?</p>
                <div class="alert alert-danger mb-0">
                    <strong><i class="fas fa-exclamation-circle"></i> This action cannot be undone!</strong>
                    <ul class="mb-0 mt-2">
                        <li>Link will be removed from your profile</li>
                        <li>ALL analytics data for this link will be deleted</li>
                        <li>This action is irreversible</li>
                    </ul>
