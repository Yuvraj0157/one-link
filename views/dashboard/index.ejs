<%-include('include/_header')%>

<div class="container">
    <h1 style="padding-top: 15px; text-align: center; font-family: 'PT Sans', sans-serif;;">Dashboard</h1>
</div>

 <!-- Main Site -->
 <main id="site-main">
    <div class="container">
       <div class="box-nav d-flex justify-between">
           <a href="/dashboard/add-link" class="border-shadow">
               <span class="text-gradient"><i class="fas fa-link"></i> New link</span>
           </a>

           <a href="/analytics" class="border-shadow">
            <span class="text-gradient">Analytics <i class="fas fa-chart-line"></i></span>
           </a>

           <a href="/dashboard/handles" class="border-shadow">
            <span class="text-gradient">Handles <i class="fas fa-globe"></i></span>
           </a>

           <a href="/appearance" class="border-shadow">
            <span class="text-gradient"> Appearance <i class="fas fa-user"></i></span>
           </a>
       </div>

       <table class="table">
           <thead class="thead-dark">
               <tr>
                   <th>ID</th>
                   <th>Title</th>
                   <th>URL</th>
                   <th>Action</th>
               </tr>
           </thead>
           <tbody>
                <% for(const [index, link] of profile.links.entries()) { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= link.title %></td>
                        <td><a style="text-decoration: none; color: black;" target="_blank" href="<%= link.url %>"><%= link.url %></a></td>
                        <td>
                            <a href="/dashboard/update-link?id=<%= link._id %>" class="btn border-shadow update">
                                <span class="text-gradient"><i class="fas fa-pencil-alt"></i></span>
                            </a>
                            <form action="/dashboard/delete-link" method="POST" style="display: inline;">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="id" value="<%= link._id %>">
                                <button type="submit" class="btn border-shadow delete" onclick="return confirm('Are you sure you want to delete this link?')">
                                    <span class="text-gradient"><i class="fas fa-times"></i></span>
                                </button>
                            </form>
                        </td>
                    </tr>
                    <% } %>
           </tbody>
       </table>
       <% if(profile.links.length==0){%>
            <tr style="text-align: center;">
                <h3>No links here . Please add a new link.</h3>
            </tr>
        <%}%>
    </div>
</main>
<!-- /Main Site -->

