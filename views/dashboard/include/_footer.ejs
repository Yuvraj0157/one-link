    <!-- Offline Indicator Script -->
    <script>
        // Offline/Online Detection
        const offlineIndicator = document.getElementById('offlineIndicator');
        
        function updateOnlineStatus() {
            if (!navigator.onLine) {
                offlineIndicator.classList.add('show');
            } else {
                offlineIndicator.classList.remove('show');
            }
        }
        
        // Check initial status
        updateOnlineStatus();
        
        // Listen for online/offline events
        window.addEventListener('online', updateOnlineStatus);
        window.addEventListener('offline', updateOnlineStatus);
        
        // Periodic check (backup for browsers that don't fire events reliably)
        setInterval(updateOnlineStatus, 5000);
        
        // Achievement Section Chevron Rotation
        const achievementsCollapse = document.getElementById('achievementsCollapse');
        const achievementChevron = document.getElementById('achievementChevron');
        
        if (achievementsCollapse && achievementChevron) {
            achievementsCollapse.addEventListener('show.bs.collapse', function () {
                achievementChevron.style.transform = 'rotate(180deg)';
                achievementChevron.style.transition = 'transform 0.3s ease';
            });
            
            achievementsCollapse.addEventListener('hide.bs.collapse', function () {
                achievementChevron.style.transform = 'rotate(0deg)';
            });
        }
    </script>
