                               value="<%= data.handles.pinterest || '' %>">
                    </div>
                    
                    <!-- TikTok -->
                    <div class="col-md-6 mb-3">
                        <label for="tiktok_url" class="form-label">
                            <i class="fab fa-tiktok"></i> TikTok
                        </label>
                        <input type="url" 
