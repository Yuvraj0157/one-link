<%-include('include/_header')%>

<div class="container" style="max-width: 900px;">
    <!-- Back Button -->
    <div class="mb-3">
        <a href="/dashboard" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>
    
    <!-- Page Header -->
    <div class="page-header">
        <h2><i class="fas fa-globe me-2"></i>Social Handles</h2>
        <p>Connect your social media accounts and contact information</p>
    </div>
    
    <!-- Form Card -->
    <div class="card">
        <div class="card-body">
            <form id="handle_form">
                <div class="row">
                    <!-- Email -->
                    <div class="col-md-6 mb-3">
                        <label for="email_url" class="form-label">
                            <i class="fas fa-envelope"></i> Email
                        </label>
                        <input type="email" 
                               class="form-control" 
                               id="email_url" 
                               name="email" 
                               placeholder="your@email.com"
                               value="<%= data.handles.email || '' %>">
                    </div>
                    
                    <!-- Facebook -->
                    <div class="col-md-6 mb-3">
                        <label for="facebook_url" class="form-label">
                            <i class="fab fa-facebook"></i> Facebook
                        </label>
                        <input type="url" 
                               class="form-control" 
                               id="facebook_url" 
                               name="facebook" 
                               placeholder="https://facebook.com/yourpage"
                               value="<%= data.handles.facebook || '' %>">
                    </div>
                    
                    <!-- Twitter -->
                    <div class="col-md-6 mb-3">
                        <label for="twitter_url" class="form-label">
                            <i class="fab fa-twitter"></i> Twitter / X
                        </label>
                        <input type="url" 
                               class="form-control" 
                               id="twitter_url" 
                               name="twitter" 
                               placeholder="https://x.com/username"
                               value="<%= data.handles.twitter || '' %>">
                    </div>
                    
                    <!-- Instagram -->
                    <div class="col-md-6 mb-3">
                        <label for="instagram_url" class="form-label">
                            <i class="fab fa-instagram"></i> Instagram
                        </label>
                        <input type="url" 
                               class="form-control" 
                               id="instagram_url" 
                               name="instagram" 
                               placeholder="https://instagram.com/username"
                               value="<%= data.handles.instagram || '' %>">
                    </div>
                    
                    <!-- YouTube -->
                    <div class="col-md-6 mb-3">
                        <label for="youtube_url" class="form-label">
                            <i class="fab fa-youtube"></i> YouTube
                        </label>
                        <input type="url" 
                               class="form-control" 
                               id="youtube_url" 
                               name="youtube" 
                               placeholder="https://youtube.com/@channel"
                               value="<%= data.handles.youtube || '' %>">
                    </div>
                    
                    <!-- LinkedIn -->
                    <div class="col-md-6 mb-3">
                        <label for="linkedin_url" class="form-label">
                            <i class="fab fa-linkedin"></i> LinkedIn
                        </label>
                        <input type="url" 
                               class="form-control" 
                               id="linkedin_url" 
                               name="linkedin" 
                               placeholder="https://linkedin.com/in/username"
                               value="<%= data.handles.linkedin || '' %>">
                    </div>
                    
                    <!-- WhatsApp -->
                    <div class="col-md-6 mb-3">
                        <label for="whatsapp_url" class="form-label">
                            <i class="fab fa-whatsapp"></i> WhatsApp
                        </label>
                        <input type="url" 
                               class="form-control" 
                               id="whatsapp_url" 
                               name="whatsapp" 
                               placeholder="https://wa.me/1234567890"
                               value="<%= data.handles.whatsapp || '' %>">
                    </div>
                    
                    <!-- Telegram -->
                    <div class="col-md-6 mb-3">
                        <label for="telegram_url" class="form-label">
                            <i class="fab fa-telegram"></i> Telegram
                        </label>
                        <input type="url" 
                               class="form-control" 
                               id="telegram_url" 
                               name="telegram" 
                               placeholder="https://t.me/username"
                               value="<%= data.handles.telegram || '' %>">
                    </div>
                    
                    <!-- Signal -->
                    <div class="col-md-6 mb-3">
                        <label for="signal_url" class="form-label">
                            <i class="fas fa-comment-dots"></i> Signal
                        </label>
                        <input type="url" 
                               class="form-control" 
                               id="signal_url" 
                               name="signal" 
                               placeholder="https://signal.group/..."
                               value="<%= data.handles.signal || '' %>">
                    </div>
                    
                    <!-- Discord -->
                    <div class="col-md-6 mb-3">
                        <label for="discord_url" class="form-label">
                            <i class="fab fa-discord"></i> Discord
                        </label>
                        <input type="url" 
                               class="form-control" 
                               id="discord_url" 
                               name="discord" 
                               placeholder="https://discord.gg/invite"
                               value="<%= data.handles.discord || '' %>">
                    </div>
                    
                    <!-- Pinterest -->
                    <div class="col-md-6 mb-3">
                        <label for="pinterest_url" class="form-label">
                            <i class="fab fa-pinterest"></i> Pinterest
                        </label>
                        <input type="url" 
                               class="form-control" 
                               id="pinterest_url" 
                               name="pinterest" 
