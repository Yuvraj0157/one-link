                               placeholder="https://tiktok.com/@username"
                               value="<%= data.handles.tiktok || '' %>">
                    </div>
                    
                    <!-- Spotify -->
                    <div class="col-md-6 mb-3">
                        <label for="spotify_url" class="form-label">
                            <i class="fab fa-spotify"></i> Spotify
                        </label>
                        <input type="url" 
                               class="form-control" 
                               id="spotify_url" 
                               name="spotify" 
                               placeholder="https://open.spotify.com/artist/..."
                               value="<%= data.handles.spotify || '' %>">
                    </div>
                    
                    <!-- Snapchat -->
                    <div class="col-md-6 mb-3">
                        <label for="snapchat_url" class="form-label">
                            <i class="fab fa-snapchat"></i> Snapchat
                        </label>
                        <input type="url" 
                               class="form-control" 
                               id="snapchat_url" 
                               name="snapchat" 
                               placeholder="https://snapchat.com/add/username"
                               value="<%= data.handles.snapchat || '' %>">
                    </div>
                    
                    <!-- Payment -->
                    <div class="col-md-6 mb-3">
                        <label for="payment_url" class="form-label">
                            <i class="fas fa-dollar-sign"></i> Payment
                        </label>
                        <input type="url" 
                               class="form-control" 
                               id="payment_url" 
                               name="payment" 
                               placeholder="https://venmo.com/username"
                               value="<%= data.handles.payment || '' %>">
                    </div>
                    
                    <!-- GitHub -->
                    <div class="col-md-6 mb-3">
                        <label for="github_url" class="form-label">
                            <i class="fab fa-github"></i> GitHub
                        </label>
                        <input type="url" 
                               class="form-control" 
                               id="github_url" 
                               name="github" 
