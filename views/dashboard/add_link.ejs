<%-include('include/_header')%>

<div class="container" style="max-width: 800px;">
    <!-- Back Button -->
    <div class="mb-3">
        <a href="/dashboard" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>
    
    <!-- Page Header -->
    <div class="page-header">
        <h2><i class="fas fa-link me-2"></i>New Link</h2>
        <p>Use the form below to create a new link for your profile</p>
    </div>
    
    <!-- Form Card -->
    <div class="card">
        <div class="card-body">
            <form action="/dashboard/add-link" method="POST" id="add_link_form">
                <div class="mb-3">
                    <label for="title" class="form-label">
                        <i class="fas fa-heading"></i> Link Title <span class="text-danger">*</span>
                    </label>
                    <input type="text" 
                           class="form-control" 
                           id="title" 
                           name="title" 
                           placeholder="e.g., My Portfolio, Instagram, YouTube Channel" 
                           required>
                    <small class="form-text text-muted">This will be displayed as the link name on your profile</small>
                </div>
                
                <div class="mb-3">
                    <label for="url" class="form-label">
                        <i class="fas fa-globe"></i> URL <span class="text-danger">*</span>
                    </label>
                    <input type="url"
                           class="form-control"
                           id="url"
                           name="url"
                           placeholder="https://example.com"
                           required>
                    <small class="form-text text-muted">Enter the full URL including https://</small>
                </div>
                
                <div class="mb-4">
                    <label for="icon" class="form-label">
                        <i class="fas fa-icons"></i> Icon
                    </label>
                    <select class="form-select" id="icon" name="icon">
                        <option value="fas fa-link">🔗 Default Link</option>
                        <option value="fas fa-globe">🌐 Website</option>
                        <option value="fab fa-instagram">📷 Instagram</option>
                        <option value="fab fa-twitter">🐦 Twitter</option>
                        <option value="fab fa-facebook">👥 Facebook</option>
                        <option value="fab fa-youtube">📺 YouTube</option>
                        <option value="fab fa-linkedin">💼 LinkedIn</option>
                        <option value="fab fa-github">💻 GitHub</option>
                        <option value="fab fa-tiktok">🎵 TikTok</option>
                        <option value="fab fa-spotify">🎧 Spotify</option>
                        <option value="fab fa-discord">💬 Discord</option>
                        <option value="fab fa-telegram">✈️ Telegram</option>
                        <option value="fab fa-whatsapp">📱 WhatsApp</option>
                        <option value="fab fa-snapchat">👻 Snapchat</option>
                        <option value="fab fa-pinterest">📌 Pinterest</option>
                        <option value="fab fa-reddit">🤖 Reddit</option>
                        <option value="fab fa-twitch">🎮 Twitch</option>
                        <option value="fas fa-envelope">✉️ Email</option>
                        <option value="fas fa-phone">📞 Phone</option>
                        <option value="fas fa-shopping-cart">🛒 Shop</option>
                        <option value="fas fa-blog">📝 Blog</option>
                        <option value="fas fa-book">📚 Portfolio</option>
                        <option value="fas fa-music">🎵 Music</option>
                        <option value="fas fa-video">🎬 Video</option>
                        <option value="fas fa-camera">📸 Photography</option>
                        <option value="fas fa-heart">❤️ Support</option>
                        <option value="fas fa-donate">💰 Donate</option>
                        <option value="fas fa-file-pdf">📄 PDF/Document</option>
                    </select>
                    <small class="form-text text-muted">Choose an icon that represents your link</small>
                </div>
                
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-plus-circle"></i> Add Link
                    </button>
                    <a href="/dashboard" class="btn btn-outline-secondary">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
    
    <!-- Help Card -->
    <div class="card mt-4 border-info">
        <div class="card-body">
            <h6 class="card-title"><i class="fas fa-info-circle text-info"></i> Tips</h6>
            <ul class="mb-0 small">
                <li>Use descriptive titles that clearly identify where the link goes</li>
                <li>Make sure URLs start with https:// or http://</li>
                <li>You can reorder links later from the dashboard</li>
                <li>Links can be archived if you want to hide them temporarily</li>
            </ul>
        </div>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

<%-include('include/_footer')%>