<%-include('../dashboard/include/_header')%>

<div class="container">
    <!-- Back Navigation & Preview Button -->
    <div class="mb-3 d-flex justify-content-between align-items-center">
        <a href="/dashboard" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
        </a>
        <a href="/profile/<%= user.username %>" target="_blank" class="btn btn-success">
            <i class="fas fa-eye me-2"></i>Preview Profile
        </a>
    </div>

    <!-- Page Header -->
    <div class="page-header">
        <h2><i class="fas fa-palette me-2"></i>Appearance Settings</h2>
        <p>Customize your profile's look and feel</p>
    </div>

        <!-- Error Message -->
        <% if (messages.error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i><%= messages.error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <!-- Appearance Form - Single Card -->
        <form action="/appearance" method="POST" id="appearance_form" enctype="multipart/form-data">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-4">
                        <i class="fas fa-user-edit me-2"></i>Profile Settings
                    </h5>

                    <div class="row">
                        <!-- Left Column: Profile Photo -->
                        <div class="col-lg-4 col-md-5 mb-4 mb-md-0">
                            <div class="text-center">
                                <h6 class="fw-semibold mb-3">
                                    <i class="fas fa-image me-2 text-primary"></i>Profile Photo
                                </h6>
                                
                                <!-- Profile Photo Display -->
                                <div class="position-relative d-inline-block mb-3">
                                    <% if(data.photo){ %>
                                        <img id="profilePhoto" src="<%= data.photo %>" data-photo="<%= data.photo %>"
                                             class="rounded-circle border border-3 border-primary"
                                             style="width: 150px; height: 150px; object-fit: cover;"
                                             alt="Profile Photo" />
                                    <% } else { %>
                                        <div id="profilePhoto" class="rounded-circle border border-3 border-secondary bg-light d-flex align-items-center justify-content-center"
                                             style="width: 150px; height: 150px;">
                                            <i class="fas fa-user fa-4x text-secondary"></i>
                                        </div>
                                    <% } %>
                                </div>

                                <!-- Hidden File Input -->
                                <input id="profilepic" name="file" type="file" accept="image/*" style="display: none;" />

                                <!-- Upload/Delete Buttons -->
                                <div class="d-grid gap-2">
                                    <button type="button" id="uploadBtn" class="btn btn-primary btn-sm">
                                        <i class="fas fa-upload me-2"></i>Choose Photo
                                    </button>
                                    <% if(data.photo) {%>
                                        <button type="button" id="deleteBtn" class="btn btn-outline-danger btn-sm">
                                            <i class="fas fa-trash me-2"></i>Remove Photo
                                        </button>
                                    <% } %>
                                </div>

                                <div class="text-muted small mt-3">
                                    <i class="fas fa-info-circle me-1"></i>
                                    Auto-resized to 800x800px
                                </div>
                            </div>
                        </div>

                        <!-- Right Column: Profile Details -->
                        <div class="col-lg-8 col-md-7">
                            <!-- Profile Title -->
                            <div class="mb-3">
                                <label for="profileTitle" class="form-label fw-semibold">
                                    <i class="fas fa-heading me-2 text-primary"></i>Profile Title
                                </label>
                                <input
                                    id="profileTitle"
                                    type="text"
                                    name="title"
                                    class="form-control"
                                    value="<%= data.title || '' %>"
                                    placeholder="e.g., Social Media Manager, Business Owner"
                                    maxlength="100"
                                />
                                <div class="form-text">
                                    A catchy title that describes you or your brand
                                </div>
                            </div>

                            <!-- Bio -->
                            <div class="mb-3">
                                <label for="profileBio" class="form-label fw-semibold">
                                    <i class="fas fa-align-left me-2 text-primary"></i>Bio
                                </label>
                                <textarea
                                    id="profileBio"
                                    name="bio"
                                    class="form-control"
                                    rows="4"
                                    placeholder="Tell your visitors about yourself..."
                                    maxlength="500"
                                ><%= data.bio || '' %></textarea>
                                <div class="form-text">
                                    Brief description for your profile (max 500 characters)
                                </div>
                            </div>

                            <!-- Theme Selection -->
                            <div class="mb-4">
                                <label for="profileTheme" class="form-label fw-semibold">
                                    <i class="fas fa-palette me-2 text-primary"></i>Theme
                                </label>
                                <div class="row g-2">
                                    <div class="col-md-8">
                                        <select name="theme" id="profileTheme" class="form-select">
                                            <option value="default" <%=data.theme==='default' ? 'selected' : '' %>>Default</option>
                                            <option value="dark" <%=data.theme==='dark' ? 'selected' : '' %>>Dark</option>
                                            <option value="wave" <%=data.theme==='wave' ? 'selected' : '' %>>Wave</option>
                                            <option value="purple" <%=data.theme==='purple' ? 'selected' : '' %>>Purple</option>
                                            <option value="hexagonal" <%=data.theme==='hexagonal' ? 'selected' : '' %>>Hexagonal</option>
                                            <option value="bluedot" <%=data.theme==='bluedot' ? 'selected' : '' %>>BlueDot</option>
                                            <option value="purpledot" <%=data.theme==='purpledot' ? 'selected' : '' %>>PurpleDot</option>
                                            <option value="shapes" <%=data.theme==='shapes' ? 'selected' : '' %>>Shapes</option>
                                            <option value="snow" <%=data.theme==='snow' ? 'selected' : '' %>>Snow</option>
                                            <option value="moon" <%=data.theme==='moon' ? 'selected' : '' %>>Moon</option>
                                            <option value="soundwave" <%=data.theme==='soundwave' ? 'selected' : '' %>>SoundWave</option>
                                            <option value="abstractpaper" <%=data.theme==='abstractpaper' ? 'selected' : '' %>>AbstractPaper</option>
                                            <option value="stockmarket" <%=data.theme==='stockmarket' ? 'selected' : '' %>>StockMarket</option>
                                            <option value="worldmapindia" <%=data.theme==='worldmapindia' ? 'selected' : '' %>>WorldMap-India</option>
                                            <option value="sprinkle" <%=data.theme==='sprinkle' ? 'selected' : '' %>>Sprinkle</option>
                                            <option value="meteor" <%=data.theme==='meteor' ? 'selected' : '' %>>Meteor</option>
                                            <option value="masscircles" <%=data.theme==='masscircles' ? 'selected' : '' %>>MassCircles</option>
                                            <option value="animatedshape" <%=data.theme==='animatedshape' ? 'selected' : '' %>>AnimatedShape</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <button type="button" class="btn btn-outline-primary w-100 modal-open">
                                            <i class="fas fa-eye me-2"></i>Preview
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Submit Button -->
                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-save me-2"></i>Save All Changes
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
        
        <!-- Profile Badge Generator Card -->
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-body">
                <h5 class="card-title mb-4">
                    <i class="fas fa-award me-2"></i>Profile Badge Generator
                </h5>
                <p class="text-muted mb-3">
                    Generate embeddable badges to showcase your OneLink profile on websites, GitHub, or social media.
                </p>
                
                <!-- Badge Style Selection -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-palette me-2 text-primary"></i>Badge Style
                    </label>
                    <div class="btn-group w-100" role="group">
                        <input type="radio" class="btn-check" name="badgeStyle" id="badgeFlat" value="flat" checked>
                        <label class="btn btn-outline-primary" for="badgeFlat">Flat</label>
                        
                        <input type="radio" class="btn-check" name="badgeStyle" id="badgeGradient" value="gradient">
                        <label class="btn btn-outline-primary" for="badgeGradient">Gradient</label>
                        
                        <input type="radio" class="btn-check" name="badgeStyle" id="badgeMinimal" value="minimal">
                        <label class="btn btn-outline-primary" for="badgeMinimal">Minimal</label>
                    </div>
                </div>
                
                <!-- Badge Preview -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Preview</label>
                    <div class="p-4 bg-light rounded text-center" id="badgePreview">
                        <img id="badgeImage" src="" alt="Profile Badge" style="max-width: 100%; height: auto;">
                    </div>
                </div>
                
                <!-- Badge Code Sections -->
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">
                            <i class="fab fa-markdown me-2 text-primary"></i>Markdown Code
                        </label>
                        <div class="input-group">
                            <input type="text" class="form-control font-monospace small" id="markdownCode" readonly>
                            <button class="btn btn-outline-secondary copy-badge-btn" type="button" data-type="markdown">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">
                            <i class="fab fa-html5 me-2 text-primary"></i>HTML Code
                        </label>
                        <div class="input-group">
                            <input type="text" class="form-control font-monospace small" id="htmlCode" readonly>
                            <button class="btn btn-outline-secondary copy-badge-btn" type="button" data-type="html">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                    </div>
                </div>
                
                <div class="alert alert-info mb-0">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Tip:</strong> Use these badges on your GitHub README, personal website, or social media profiles to drive traffic to your OneLink page!
                </div>
            </div>
        </div>
    </div>
</main>
<!-- /Main Site -->

