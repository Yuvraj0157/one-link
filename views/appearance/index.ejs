                            <div class="card-body text-center p-2">
                                <div class="theme-preview-container mb-2 rounded overflow-hidden border" style="height: 150px; background-color: #0E2A47;"></div>
                                <h6 class="card-title mb-0 fw-bold">AnimatedShape</h6>
                            </div>
                        </div>
                    </div>

                    <!-- Meteor Theme -->
                    <div class="col-md-4 col-sm-6">
                        <div class="theme-card card h-100 border-2 cursor-pointer" data-theme="meteor">
                            <div class="card-body text-center p-2">
                                <div class="theme-preview-container mb-2 rounded overflow-hidden border" style="height: 150px; background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' version='1.1' xmlns:xlink='http://www.w3.org/1999/xlink' xmlns:svgjs='http://svgjs.com/svgjs' width='1440' height='560' preserveAspectRatio='none' viewBox='0 0 1440 560'%3e%3cg mask='url(%26quot%3b%23SvgjsMask1000%26quot%3b)' fill='none'%3e%3crect width='1440' height='560' x='0' y='0' fill='%230e2a47'%3e%3c/rect%3e%3cpath d='M1330 192L1329 -110' stroke-width='10' stroke='url(%23SvgjsLinearGradient1001)' stroke-linecap='round' class='Down'%3e%3c/path%3e%3c/g%3e%3c/svg%3e"); background-size: cover; background-position: center;"></div>
                                <h6 class="card-title mb-0 fw-bold">Meteor</h6>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Cancel
                </button>
                <button type="button" class="btn btn-success" id="previewTheme">
                    <i class="fas fa-eye me-2"></i>Live Preview
                </button>
                <button type="button" class="btn btn-primary" id="confirmTheme">
                    <i class="fas fa-check me-2"></i>Apply Theme
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Success Toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
    <div id="successToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="fas fa-check-circle me-2"></i>
                <span id="successMessage">Profile photo deleted successfully!</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<!-- Error Toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
    <div id="errorToast" class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="fas fa-exclamation-circle me-2"></i>
                <span id="errorMessage">An error occurred!</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<style>
    .cursor-pointer {
        cursor: pointer;
        transition: all 0.3s ease;
    }
    
    .theme-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        border-color: #667eea !important;
    }
    
    .theme-card.selected {
        border-color: #667eea !important;
        background-color: #f8f9fa;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // File upload preview
        const fileUpload = document.getElementById('profilepic');
        const profilePhoto = document.getElementById('profilePhoto');
        const uploadBtn = document.getElementById('uploadBtn');
        const deleteBtn = document.getElementById('deleteBtn');
        
        // Handle file selection with validation and resizing
        if (fileUpload) {
            fileUpload.addEventListener('change', function(e) {
                if (this.files && this.files[0]) {
                    const file = this.files[0];
                    
                    // Check file type
                    if (!file.type.startsWith('image/')) {
                        showErrorToast('Please select an image file');
                        this.value = '';
                        return;
                    }
                    
                    // Check file size (max 5MB)
                    if (file.size > 5 * 1024 * 1024) {
                        showErrorToast('Image size must be less than 5MB');
                        this.value = '';
                        return;
                    }
                    
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const img = new Image();
                        img.onload = function() {
                            // Check dimensions
                            if (img.width > 2000 || img.height > 2000) {
                                // Resize image
                                resizeImage(img, 2000, 2000, function(resizedDataUrl) {
                                    updateProfilePhoto(resizedDataUrl);
                                    // Update file input with resized image
                                    dataURLtoFile(resizedDataUrl, file.name).then(function(resizedFile) {
                                        const dataTransfer = new DataTransfer();
                                        dataTransfer.items.add(resizedFile);
                                        fileUpload.files = dataTransfer.files;
                                    });
                                });
                            } else {
                                updateProfilePhoto(e.target.result);
                            }
                        };
                        img.src = e.target.result;
                    };
                    reader.readAsDataURL(file);
                }
            });
        }
        
        // Function to update profile photo display
        function updateProfilePhoto(dataUrl) {
            if (profilePhoto.tagName === 'IMG') {
                profilePhoto.src = dataUrl;
            } else {
                const newImg = document.createElement('img');
                newImg.id = 'profilePhoto';
                newImg.src = dataUrl;
                newImg.className = 'rounded-circle border border-3 border-primary';
                newImg.style.cssText = 'width: 150px; height: 150px; object-fit: cover;';
                newImg.alt = 'Profile Photo';
                profilePhoto.parentNode.replaceChild(newImg, profilePhoto);
            }
        }
        
        // Function to resize image
        function resizeImage(img, maxWidth, maxHeight, callback) {
            let width = img.width;
            let height = img.height;
            
            // Calculate new dimensions
            if (width > height) {
                if (width > maxWidth) {
                    height = height * (maxWidth / width);
                    width = maxWidth;
                }
            } else {
                if (height > maxHeight) {
                    width = width * (maxHeight / height);
                    height = maxHeight;
                }
            }
            
            // Create canvas and resize
            const canvas = document.createElement('canvas');
            canvas.width = width;
            canvas.height = height;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, width, height);
            
            callback(canvas.toDataURL('image/jpeg', 0.9));
        }
        
        // Function to convert data URL to File
        function dataURLtoFile(dataUrl, filename) {
            return fetch(dataUrl)
                .then(res => res.blob())
                .then(blob => new File([blob], filename, { type: 'image/jpeg' }));
        }
        
        // Open file selector when upload button is clicked
        if (uploadBtn && fileUpload) {
            uploadBtn.addEventListener('click', function() {
                fileUpload.click();
            });
        }
        
        // Handle delete action
        if (deleteBtn) {
            deleteBtn.addEventListener('click', function() {
                const photoElement = document.getElementById('profilePhoto');
                const uri = photoElement.dataset ? photoElement.dataset.photo : null;
                
                if (!uri) {
                    showErrorToast('No photo to delete');
                    return;
                }
                
                // Use fetch API
                fetch('/appearance/delete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ uri: uri })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.status === 'success') {
                        showSuccessToast(data.message);
                        setTimeout(() => {
                            window.location.reload();
                        }, 1500);
                    } else {
                        showErrorToast(data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showErrorToast('An error occurred while deleting the photo');
                });
            });
        }
        
        // Theme modal functionality
        const modalOpenBtn = document.querySelector('.modal-open');
        const themeModal = new bootstrap.Modal(document.getElementById('themeModal'));
        const themeCards = document.querySelectorAll('.theme-card');
        const profileThemeSelect = document.getElementById('profileTheme');
        const confirmThemeBtn = document.getElementById('confirmTheme');
        let selectedTheme = profileThemeSelect.value;
        
        // Open theme modal
        if (modalOpenBtn) {
            modalOpenBtn.addEventListener('click', function(e) {
                e.preventDefault();
                themeModal.show();
                
                // Highlight currently selected theme
                themeCards.forEach(card => {
                    if (card.dataset.theme === selectedTheme) {
                        card.classList.add('selected');
                    } else {
                        card.classList.remove('selected');
                    }
                });
            });
        }
        
        // Handle theme card clicks
        themeCards.forEach(card => {
            card.addEventListener('click', function() {
                // Remove selected class from all cards
                themeCards.forEach(c => c.classList.remove('selected'));
                
                // Add selected class to clicked card
                this.classList.add('selected');
                
                // Update selected theme
                selectedTheme = this.dataset.theme;
            });
        });
        
        // Preview theme in new tab
        const previewThemeBtn = document.getElementById('previewTheme');
        if (previewThemeBtn) {
            previewThemeBtn.addEventListener('click', function() {
                const username = '<%= user.username %>';
                const previewUrl = `/profile/${username}?preview=${selectedTheme}`;
                window.open(previewUrl, '_blank');
            });
        }
        
        // Confirm theme selection
        if (confirmThemeBtn) {
            confirmThemeBtn.addEventListener('click', function() {
                profileThemeSelect.value = selectedTheme;
                themeModal.hide();
                
                // Show success message
                showSuccessToast('Theme selected! Remember to save your changes.');
            });
        }
        
        // Profile Badge Generator
        const badgeStyles = document.querySelectorAll('input[name="badgeStyle"]');
        const badgeImage = document.getElementById('badgeImage');
        const markdownCode = document.getElementById('markdownCode');
        const htmlCode = document.getElementById('htmlCode');
        const username = '<%= user.username %>';
        const baseUrl = window.location.origin;
        
        function updateBadge() {
            const selectedStyle = document.querySelector('input[name="badgeStyle"]:checked').value;
            let badgeUrl = '';
            
            // Generate badge URL based on style
            if (selectedStyle === 'flat') {
                badgeUrl = `https://img.shields.io/badge/OneLink-${username}-667eea?style=flat&logo=data:image/svg+xml;base64,`;
            } else if (selectedStyle === 'gradient') {
                badgeUrl = `https://img.shields.io/badge/OneLink-${username}-667eea?style=for-the-badge&logo=data:image/svg+xml;base64,`;
            } else {
                badgeUrl = `https://img.shields.io/badge/OneLink-${username}-667eea?style=flat-square&logo=data:image/svg+xml;base64,`;
            }
            
            const profileUrl = `${baseUrl}/profile/${username}`;
            
            // Update badge image
            badgeImage.src = badgeUrl;
            
            // Update markdown code
            markdownCode.value = `[![OneLink Profile](${badgeUrl})](${profileUrl})`;
            
            // Update HTML code
            htmlCode.value = `<a href="${profileUrl}"><img src="${badgeUrl}" alt="OneLink Profile"></a>`;
        }
        
        // Initialize badge
        updateBadge();
        
        // Update badge when style changes
        badgeStyles.forEach(radio => {
            radio.addEventListener('change', updateBadge);
        });
        
        // Toast notification functions
        function showSuccessToast(message) {
            const toastElement = document.getElementById('successToast');
            const messageElement = document.getElementById('successMessage');
            messageElement.textContent = message;
            const toast = new bootstrap.Toast(toastElement);
            toast.show();
        }
        
        function showErrorToast(message) {
            const toastElement = document.getElementById('errorToast');
            const messageElement = document.getElementById('errorMessage');
            messageElement.textContent = message;
            const toast = new bootstrap.Toast(toastElement);
            toast.show();
        }
    });
    
    // Copy badge code buttons (CSP-compliant event listeners)
    document.querySelectorAll('.copy-badge-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const type = this.getAttribute('data-type');
            const input = type === 'markdown' ? document.getElementById('markdownCode') : document.getElementById('htmlCode');
            
            input.select();
            input.setSelectionRange(0, 99999);
            
            navigator.clipboard.writeText(input.value).then(() => {
                const originalHTML = this.innerHTML;
                this.innerHTML = '<i class="fas fa-check"></i>';
                this.classList.add('btn-success');
                this.classList.remove('btn-outline-secondary');
                
                setTimeout(() => {
                    this.innerHTML = originalHTML;
                    this.classList.remove('btn-success');
                    this.classList.add('btn-outline-secondary');
                }, 2000);
            }).catch(err => {
                console.error('Failed to copy:', err);
            });
        });
    });
</script>

<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

